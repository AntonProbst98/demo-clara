# Copy this file to `.env.local` and fill in your key.
#
#   cp .env.local.example .env.local
#
# Google Gemini API key — used ONLY to generate the Spanish negotiation script.
# Get one at https://aistudio.google.com/apikey
#
# If this is left unset, the app still works: the /api/generate-script route
# falls back to a deterministic Spanish template and labels the script's source
# in the UI.
GEMINI_API_KEY=

# Live n8n ingest webhook — the Production URL of the Webhook node in
# collections_ingest_webhook_n8n.json. Used by /api/ingest to clean uploaded
# CSVs through n8n. Example:
#   https://<your-subdomain>.app.n8n.cloud/webhook/collections-ingest
#
# If left unset (or if n8n is unreachable), /api/ingest falls back to the
# identical in-app pipeline (src/lib/pipeline.ts) so a demo is never blocked.
N8N_INGEST_WEBHOOK_URL=

# Server-side store for the uploaded book (Upstash Redis, free tier). REQUIRED on
# Vercel, whose runtime disk is read-only — /api/ingest persists here instead.
# Get them from Vercel → Storage → Redis (auto-injected) or the Upstash console.
# Locally you can leave these blank: ingest falls back to writing the file on disk.
KV_REST_API_URL=
KV_REST_API_TOKEN=
